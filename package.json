{
  "name": "docforge",
  "version": "0.5.0",
  "description": "Convert documentation sources to Markdown for RAG ingestion.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "docforge": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin.ts",
    "pretest": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@crawlee/utils": "^3.16.0",
    "@kreuzberg/node": "^4",
    "cacheable-request": "^13.0.19",
    "cheerio": "^1",
    "commander": "^13",
    "defuddle": "^0.18.1",
    "got": "^15.0.5",
    "js-yaml": "^4",
    "keyv": "^5.6.0",
    "keyv-file": "^5.3.3",
    "linkedom": "^0.18.12",
    "p-queue": "^9.2.0",
    "sitemapper": "^4.1.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^2"
  },
  "engines": {
    "node": ">=20"
  }
}
